# ============================================================
# CropAI — Root .gitignore
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment variables (NEVER commit real secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Production builds
/client/build
/client/.pnp
/client/.pnp.js

# Testing
/client/coverage

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
server/*.log
server/**/*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Package lock files (optional — keep if you want reproducible installs)
# package-lock.json

# Temporary files
*.tmp
*.temp
