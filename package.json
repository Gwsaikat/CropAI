{
  "name": "cropai",
  "version": "2.0.0",
  "description": "AI-powered federated crop disease detection platform",
  "private": true,
  "scripts": {
    "install:all": "cd client && npm install && cd ../server && npm install",
    "dev:client": "cd client && npm start",
    "dev:server": "cd server && npm run dev",
    "start:server": "cd server && npm start",
    "build": "cd client && npm run build"
  },
  "keywords": [
    "agriculture",
    "AI",
    "crop-disease",
    "machine-learning",
    "federated-learning",
    "react",
    "nodejs",
    "supabase",
    "tensorflow"
  ],
  "author": "Gwsaikat",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.99.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.1"
  }
}
